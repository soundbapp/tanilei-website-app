# PostgreSQL (e.g. Neon) — one-time: apply 001_appointments.sql then 002_appointment_intake.sql in the Neon
# SQL editor (or locally: npm run migrate:002 if you have psql). If you already ran that SQL, you’re done.
DATABASE_URL=postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Public site URL (no trailing slash) — used in appointment and pre-visit emails. Local: http://localhost:3001
SITE_URL=https://www.tanilei.com
# Optional: only if you need the URL in browser code
# NEXT_PUBLIC_SITE_URL=https://www.tanilei.com
#
# Vercel production: Prefer setting SITE_URL to your canonical URL (e.g. https://www.tanilei.com).
# If you skip it, getSiteUrl() uses VERCEL_PROJECT_PRODUCTION_URL (your custom domain) when
# Project → Settings → Environment Variables → “System Environment Variables” is enabled.
# Otherwise it falls back to *.vercel.app — wrong for customer-facing email links.

# Resend (https://resend.com) — create an API key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Inbox(es) for business alerts and Bcc on guest messages. Comma- or semicolon-separated for multiple. The
# app also always includes tanileibeauty@outlook.com (see lib/email.ts). Default if unset: Resend’s test address.
NOTIFY_EMAIL=hello@tanilei.com;team@example.com

# "From" for all outbound mail. The domain in this address must be added and verified in Resend
# (Domains in the Resend dashboard) or Resend will reject sends. Unquote if the value has no spaces.
# Example after verification: TaniLei <bookings@tanilei.com>
# EMAIL_FROM=TaniLei <bookings@tanilei.com>
